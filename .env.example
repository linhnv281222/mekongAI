# ═══════════════════════════════════════════════════════════
# Mekong AI — Environment Variables
# Copy file nay thanh .env va dien vao
# ═══════════════════════════════════════════════════════════

# ── ANTHROPIC (bat buoc) ────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── GMAIL OAUTH2 (cho email agent) ─────────────────────────
# Tao tai: https://console.cloud.google.com
# Bat Gmail API -> OAuth2 Credentials (Desktop app)
# Chay: node gmail_oauth_setup.js de lay REFRESH_TOKEN
GMAIL_CLIENT_ID=xxxx.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-...
GMAIL_REFRESH_TOKEN=1//...
GMAIL_USER=ecyberlinh@gmail.com

# ── ERP FACENET ─────────────────────────────────────────────
# Bearer token lay tu ERP (DevTools -> Network -> copy header Authorization)
ERP_BASE_URL=https://erp.vietnhattan.com.vn/api
ERP_BEARER_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── DATABASE PostgreSQL ─────────────────────────────────────
DATABASE_URL=DATABASE_URL=postgresql://postgres:123456@localhost:5432/mechanical_ai

# ── SERVER (mac dinh) ───────────────────────────────────────
PORT=3000

# ── EMAIL AGENT ─────────────────────────────────────────────
BANVE_API_URL=http://localhost:3000
SCAN_INTERVAL_MINUTES=5

# ── GEMINI (optional - backup model) ───────────────────────
GEMINI_API_KEY=AIza...
