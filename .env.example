# ═══════════════════════════════════════════════════════════
# Mekong AI — Environment Variables
# Copy file nay thanh .env va dien vao
# ═══════════════════════════════════════════════════════════

# ── ANTHROPIC (bat buoc) ────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── GMAIL OAUTH2 (cho email agent) ─────────────────────────
# Tao tai: https://console.cloud.google.com
# Bat Gmail API -> OAuth2 Credentials kieu "Web application"
# Trong "Authorized redirect URIs" them CHINH XAC (vd):
#   http://localhost:3001/oauth2callback
# Chay: npm run oauth  (hoac node src/agents/gmailOAuthSetup.js)
# GMAIL_OAUTH_REDIRECT_URI=http://localhost:3001/oauth2callback
GMAIL_CLIENT_ID=xxxx.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-...
GMAIL_REFRESH_TOKEN=1//...
GMAIL_USER=ecyberlinh@gmail.com

# ── ERP FACENET ─────────────────────────────────────────────
# Bearer token lay tu ERP (DevTools -> Network -> copy header Authorization)
ERP_BASE_URL=https://erp.vietnhattan.com.vn/api
ERP_BEARER_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── DATABASE PostgreSQL ─────────────────────────────────────
# Docker gateway IP (host machine) + port 5432
# Chu y: thay postgres_user, postgres_password, ten_database bang gia tri thuc cua DB tren server
# Kiem tra tren server: docker exec <container_db> psql -U postgres -c "SELECT version();"
DATABASE_URL=postgresql://admin:123456aA@123@172.17.0.1:5432/planned_maintenance_system

# ── SERVER (container port, khong doi) ──────────────────────
PORT=3000

# ── EMAIL AGENT ─────────────────────────────────────────────
# Dia chi noi bo cua API trong Docker network
BANVE_API_URL=http://mekong-api:3000
SCAN_INTERVAL_SECONDS=30
# (Docker) File job chung API + agent — compose set AGENT_JOBS_FILE=/data/agent_jobs.json
# AGENT_JOBS_FILE=

# ── GEMINI (optional - backup model) ───────────────────────
GEMINI_API_KEY=AIza...
